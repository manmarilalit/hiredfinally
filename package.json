{
  "name": "jobtracker",
  "version": "1.0.0",
  "description": "A job application tracker",
  "license": "ISC",
  "author": "Lalit Manmari",
  "type": "commonjs",
  "main": "out/electron/index.js",
  "private": true,
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "copy-html": "node -e \"require('fs').copyFileSync('src/electron/home.html', 'out/electron/home.html')\"",
    "start": "electron ./out/electron/index.js",
    "build": "tsc && npm run copy-html",
    "build:watch": "tsc --watch & npm run copy-html",
    "postinstall": "electron-rebuild",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "git:auto": "bash git-auto.sh"
  },
  "build": {
    "appId": "com.lalitmanmari.jobtracker",
    "productName": "JobTracker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.ico",
      "sign": null,
      "signingHashAlgorithms": ["sha256"]
    },
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "electron": "^39.2.7",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.5.0",
    "sql.js": "^1.13.0"
  }
}