{
  "name": "hiredfinally",
  "version": "1.0.0",
  "description": "A job application tracker",
  "license": "ISC",
  "author": "Lalit Manmari",
  "type": "commonjs",
  "main": "out/electron/index.js",
  "private": true,

  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",

    "copy-html": "node -e \"['home','settings','pipeline'].forEach(f=>require('fs').copyFileSync('src/electron/'+f+'.html','out/electron/'+f+'.html'))\"",

    "start": "electron ./out/electron/index.js",

    "build": "tsc && npm run copy-html",

    "build:watch": "tsc --watch & npm run copy-html",

    "postinstall": "electron-rebuild",

    "dist": "npm run build && electron-builder",

    "dist:win": "npm run build && electron-builder --win",

    "dist:mac": "npm run build && electron-builder --mac",

    "dist:linux": "npm run build && electron-builder --linux",

    "git:auto": "bash git-auto.sh"
  },

  "build": {
    "appId": "com.lalitmanmari.hiredfinally",
    "productName": "HiredFinally",

    "asar": true,

    "directories": {
      "output": "dist"
    },

    "files": [
      "out/**/*",
      "package.json",
      "node_modules/**/*"
    ],

    "publish": {
      "provider": "github",
      "owner": "manmarilalit",
      "repo": "hiredfinally"
    },

    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico",
      "sign": null,
      "signingHashAlgorithms": [
        "sha256"
      ]
    },

    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity"
    },

    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },

  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "electron": "^39.2.7",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.9.3"
  },

  "dependencies": {
    "better-sqlite3": "^12.5.0",
    "sql.js": "^1.13.0",
    "electron-updater": "^6.3.9"
  }
}